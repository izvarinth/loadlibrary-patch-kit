+/* ntdll Nt* minimal implementations */
+static NTSTATUS WINAPI NtCreateFile(PHANDLE FileHandle,
+                                    ACCESS_MASK DesiredAccess,
+                                    POBJECT_ATTRIBUTES ObjectAttributes,
+                                    PIO_STATUS_BLOCK IoStatusBlock,
+                                    PLARGE_INTEGER AllocationSize,
+                                    ULONG FileAttributes,
+                                    ULONG ShareAccess,
+                                    ULONG CreateDisposition,
+                                    ULONG CreateOptions,
+                                    PVOID EaBuffer,
+                                    ULONG EaLength)
+{
+    (void)DesiredAccess; (void)AllocationSize; (void)FileAttributes;
+    (void)ShareAccess; (void)CreateOptions; (void)EaBuffer; (void)EaLength;
+
+    if (!FileHandle || !ObjectAttributes || !ObjectAttributes->ObjectName) {
+        if (IoStatusBlock)
+            IoStatusBlock->Status = STATUS_INVALID_PARAMETER;
+        return STATUS_INVALID_PARAMETER;
+    }
+
+    char *path = ansi_from_unicode_string(ObjectAttributes->ObjectName);
+    normalize_path(path);
+    FILE *fp = path ? open_file_for_disposition(path, CreateDisposition) : NULL;
+    if (!fp && path) {
+        char *resolved = resolve_case_path(path);
+        if (resolved) {
+            fp = open_file_for_disposition(resolved, CreateDisposition);
+            free(resolved);
+        }
+    }
+    if (!fp && trace_files_enabled() && path) {
+        LogMessage("NtCreateFile failed: %s", path);
+    }
+    free(path);
+
+    if (!fp) {
+        if (IoStatusBlock)
+            IoStatusBlock->Status = STATUS_ACCESS_DENIED;
+        return STATUS_ACCESS_DENIED;
+    }
+
+    *FileHandle = fp;
+    if (IoStatusBlock) {
+        IoStatusBlock->Status = STATUS_SUCCESS;
+        IoStatusBlock->Information = 0;
+    }
+    return STATUS_SUCCESS;
+}
+
+static NTSTATUS WINAPI NtOpenFile(PHANDLE FileHandle,
+                                  ACCESS_MASK DesiredAccess,
+                                  POBJECT_ATTRIBUTES ObjectAttributes,
+                                  PIO_STATUS_BLOCK IoStatusBlock,
+                                  ULONG ShareAccess,
+                                  ULONG OpenOptions)
+{
+    return NtCreateFile(FileHandle,
+                        DesiredAccess,
+                        ObjectAttributes,
+                        IoStatusBlock,
+                        NULL,
+                        0,
+                        ShareAccess,
+                        1,
+                        OpenOptions,
+                        NULL,
+                        0);
+}
