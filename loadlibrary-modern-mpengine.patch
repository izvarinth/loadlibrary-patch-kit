+static char *ansi_from_unicode_string(PUNICODE_STRING us)
+{
+    if (!us || !us->Buffer || us->Length == 0)
+        return NULL;
+    size_t chars = us->Length / sizeof(WCHAR);
+    char *out = calloc(chars + 1, 1);
+    if (!out)
+        return NULL;
+    for (size_t i = 0; i < chars; ++i)
+        out[i] = (char)us->Buffer[i];
+    out[chars] = '\0';
+    return out;
+}
