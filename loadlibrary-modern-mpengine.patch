+
+#define FILE_MAPPING_MAGIC 0x4d41504dU /* 'MAPM' */
+#define THREAD_HANDLE_MAGIC 0x54485244U /* 'THRD' */
+
+struct thread_handle {
+    uint32_t magic;
+    pthread_t thread;
+};
+
+struct mapping_node {
+    void *addr;
+    size_t size;
+    struct mapping_node *next;
+};
+
+static struct mapping_node *g_mappings;
+
+static void register_mapping(void *addr, size_t size)
+{
+    struct mapping_node *node = malloc(sizeof(*node));
+    if (!node)
+        return;
+    node->addr = addr;
+    node->size = size;
+    node->next = g_mappings;
+    g_mappings = node;
+}
+
+static size_t unregister_mapping(void *addr)
+{
+    struct mapping_node **pp = &g_mappings;
+    while (*pp) {
+        if ((*pp)->addr == addr) {
+            struct mapping_node *node = *pp;
+            size_t size = node->size;
+            *pp = node->next;
+            free(node);
+            return size;
+        }
+        pp = &(*pp)->next;
+    }
+    return 0;
+}
+
+int is_thread_handle(HANDLE h)
+{
+    struct thread_handle *th = (struct thread_handle *)h;
+    return th && th->magic == THREAD_HANDLE_MAGIC;
+}
+
+void close_thread_handle(HANDLE h)
+{
+    struct thread_handle *th = (struct thread_handle *)h;
+    if (!th || th->magic != THREAD_HANDLE_MAGIC)
+        return;
+    pthread_detach(th->thread);
+    free(th);
+}
+
+int is_file_mapping(HANDLE h)
+{
+    FILE_MAPPING *map = (FILE_MAPPING *)h;
+    return map && map->magic == FILE_MAPPING_MAGIC;
+}
+
+void close_file_mapping(HANDLE h)
+{
+    FILE_MAPPING *map = (FILE_MAPPING *)h;
+    if (!map || map->magic != FILE_MAPPING_MAGIC)
+        return;
+    free(map);
+}
