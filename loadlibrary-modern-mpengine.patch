+static FILE *open_file_for_disposition(char *path, ULONG disposition)
+{
+    const char *mode = "r";
+    switch (disposition) {
+        case 1: /* FILE_OPEN */           mode = "r";  break;
+        case 2: /* FILE_CREATE */         mode = "wx"; break;
+        case 3: /* FILE_OPEN_IF */        mode = "a+"; break;
+        case 4: /* FILE_OVERWRITE */      mode = "w";  break;
+        case 5: /* FILE_OVERWRITE_IF */   mode = "w";  break;
+        default:                          mode = "r";  break;
+    }
+    return fopen(path, mode);
+}
