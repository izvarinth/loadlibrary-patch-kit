+static DWORD WINAPI WaitForMultipleObjects(DWORD nCount, PVOID lpHandles, BOOL bWaitAll, DWORD dwMilliseconds)
+{
+    (void)dwMilliseconds;
+    if (!lpHandles || nCount == 0)
+        return WAIT_OBJECT_0;
+    HANDLE *handles = (HANDLE *)lpHandles;
+    if (bWaitAll) {
+        for (DWORD i = 0; i < nCount; ++i) {
+            if (is_thread_handle(handles[i])) {
+                struct thread_handle *th = (struct thread_handle *)handles[i];
+                pthread_join(th->thread, NULL);
+            }
+        }
+        return WAIT_OBJECT_0;
+    }
+    if (is_thread_handle(handles[0])) {
+        struct thread_handle *th = (struct thread_handle *)handles[0];
+        pthread_join(th->thread, NULL);
+    }
+    return WAIT_OBJECT_0;
+}
