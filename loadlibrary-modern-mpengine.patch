+static NTSTATUS WINAPI NtQueryInformationFile(HANDLE FileHandle,
+                                              PIO_STATUS_BLOCK IoStatusBlock,
+                                              PVOID FileInformation,
+                                              ULONG Length,
+                                              DWORD FileInformationClass)
+{
+    FILE *fp = (FILE *)FileHandle;
+    if (!fp || !FileInformation || !IoStatusBlock)
+        return STATUS_INVALID_PARAMETER;
+
+    int fd = fileno(fp);
+    struct stat st;
+    if (fstat(fd, &st) != 0)
+        return STATUS_INVALID_PARAMETER;
+
+    switch (FileInformationClass) {
+        case FileBasicInformation: {
+            if (Length < sizeof(FILE_BASIC_INFORMATION))
+                return STATUS_BUFFER_TOO_SMALL;
+            PFILE_BASIC_INFORMATION info = (PFILE_BASIC_INFORMATION)FileInformation;
+            memset(info, 0, sizeof(*info));
+            info->FileAttributes = S_ISDIR(st.st_mode) ? FILE_ATTRIBUTE_DIRECTORY : FILE_ATTRIBUTE_NORMAL;
+            break;
+        }
+        case FileStandardInformation: {
+            if (Length < sizeof(FILE_STANDARD_INFORMATION))
+                return STATUS_BUFFER_TOO_SMALL;
+            PFILE_STANDARD_INFORMATION info = (PFILE_STANDARD_INFORMATION)FileInformation;
+            memset(info, 0, sizeof(*info));
+            info->EndOfFile = st.st_size;
+            info->AllocationSize = st.st_size;
+            info->NumberOfLinks = st.st_nlink;
+            info->Directory = S_ISDIR(st.st_mode);
+            break;
+        }
+        default:
+            return STATUS_INVALID_PARAMETER;
+    }
+
+    IoStatusBlock->Status = STATUS_SUCCESS;
+    IoStatusBlock->Information = Length;
+    return STATUS_SUCCESS;
+}
