+typedef DWORD (WINAPI *LPTHREAD_START_ROUTINE)(PVOID);
+static void *thread_start_wrapper(void *arg)
+{
+    LPTHREAD_START_ROUTINE fn = ((LPTHREAD_START_ROUTINE *)arg)[0];
+    PVOID param = ((PVOID *)arg)[1];
+    free(arg);
+    if (fn)
+        fn(param);
+    return NULL;
+}
+
+static HANDLE WINAPI CreateThread(PVOID lpThreadAttributes, SIZE_T dwStackSize, PVOID lpStartAddress, PVOID lpParameter, DWORD dwCreationFlags, PDWORD lpThreadId)
+{
+    (void)lpThreadAttributes; (void)dwStackSize; (void)dwCreationFlags;
+    struct thread_handle *th = calloc(1, sizeof(*th));
+    if (!th)
+        return NULL;
+    th->magic = THREAD_HANDLE_MAGIC;
+
+    void **wrapper_args = calloc(2, sizeof(void *));
+    if (!wrapper_args) {
+        free(th);
+        return NULL;
+    }
+    wrapper_args[0] = lpStartAddress;
+    wrapper_args[1] = lpParameter;
+
+    if (pthread_create(&th->thread, NULL, thread_start_wrapper, wrapper_args) != 0) {
+        free(wrapper_args);
+        free(th);
+        return NULL;
+    }
+    if (lpThreadId)
+        *lpThreadId = (DWORD)getpid();
+    return (HANDLE)th;
+}
+DECLARE_CRT_EXPORT("CreateThread", CreateThread);
