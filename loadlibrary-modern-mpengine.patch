+static DWORD WINAPI GetTempPathA(DWORD nBufferLength, PCHAR lpBuffer)
+{
+    const char *tmp = "/tmp/";
+    DWORD len = (DWORD)strlen(tmp);
+    if (!lpBuffer || nBufferLength == 0)
+        return len;
+    if (nBufferLength <= len)
+        return len + 1;
+    memcpy(lpBuffer, tmp, len + 1);
+    return len;
+}
