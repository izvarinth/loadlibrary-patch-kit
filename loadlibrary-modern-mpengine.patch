+            if (wtd->pCatalog->pcwszMemberFilePath)
+                member = CreateAnsiFromWide(wtd->pCatalog->pcwszMemberFilePath);
+            DebugLog("WinVerifyTrust catalog: %s member: %s", catalog ? catalog : "(null)", member ? member : "(null)");
+            if (trace_wintrust_enabled())
+                LogMessage("WinVerifyTrust catalog: %s member: %s", catalog ? catalog : "(null)", member ? member : "(null)");
