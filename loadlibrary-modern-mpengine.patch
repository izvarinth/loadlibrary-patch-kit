+static int verify_with_any_catalog(const char *file)
+{
+    const char *cat_dir = getenv("MPENGINE_CATALOG_DIR");
+    if (!cat_dir || !*cat_dir)
+        cat_dir = "engine";
+
+    DIR *dir = opendir(cat_dir);
+    if (!dir)
+        return -1;
+
+    struct dirent *ent = NULL;
+    while ((ent = readdir(dir))) {
+        const char *name = ent->d_name;
+        size_t len = strlen(name);
+        if (len < 4)
+            continue;
+        if (strcasecmp(name + len - 4, ".cat") != 0)
+            continue;
+
+        char path[MAX_PATH];
+        snprintf(path, sizeof(path), "%s/%s", cat_dir, name);
+        if (run_verify_helper(file, path) == 0) {
+            closedir(dir);
+            return 0;
+        }
+    }
+
+    closedir(dir);
+    return -1;
+}
 
