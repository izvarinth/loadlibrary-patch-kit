+            break;
+    }
+
+    if (trace_wintrust_enabled())
+        LogMessage("WinVerifyTrust helper rc=%d", helper_rc);
+
+    if (helper_rc == 0) {
+        SetLastError(ERROR_SUCCESS);
+        return ERROR_SUCCESS;
+    }
+
+    SetLastError(ERROR_NOT_FOUND);
