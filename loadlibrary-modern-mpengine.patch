+static HANDLE WINAPI CreateFileMappingW(HANDLE hFile, PVOID lpAttr, DWORD flProtect, DWORD dwMaxHigh, DWORD dwMaxLow, PWCHAR lpName)
+{
+    (void)lpAttr; (void)dwMaxHigh; (void)dwMaxLow; (void)lpName;
+    FILE *fp = (FILE *)hFile;
+    if (!fp) {
+        DebugLog("%p => NULL (no file)", hFile);
+        return NULL;
+    }
+    struct stat st;
+    if (fstat(fileno(fp), &st) != 0) {
+        DebugLog("%p => NULL (fstat failed)", hFile);
+        return NULL;
+    }
+    FILE_MAPPING *map = calloc(1, sizeof(*map));
+    if (!map)
+        return NULL;
+    map->magic = FILE_MAPPING_MAGIC;
+    map->fd = fileno(fp);
+    map->size = (size_t)st.st_size;
+    map->protect = flProtect;
+    DebugLog("%p => %p (size=%zu)", hFile, map, map->size);
+    return (HANDLE)map;
+}
+DECLARE_CRT_EXPORT("CreateFileMappingW", CreateFileMappingW);
