+static BOOL WINAPI CopyFileW(PWCHAR lpExistingFileName, PWCHAR lpNewFileName, BOOL bFailIfExists)
+{
+    (void)bFailIfExists;
+    char *src = CreateAnsiFromWide(lpExistingFileName);
+    char *dst = CreateAnsiFromWide(lpNewFileName);
+    normalize_path(src);
+    normalize_path(dst);
+    FILE *in = src ? fopen(src, "rb") : NULL;
+    FILE *out = dst ? fopen(dst, "wb") : NULL;
+    if (!in || !out) {
+        if (in) fclose(in);
+        if (out) fclose(out);
+        free(src); free(dst);
+        return FALSE;
+    }
+    char buf[4096];
+    size_t n;
+    while ((n = fread(buf, 1, sizeof(buf), in)) > 0)
+        fwrite(buf, 1, n, out);
+    fclose(in);
+    fclose(out);
+    free(src); free(dst);
+    return TRUE;
+}
+DECLARE_CRT_EXPORT("CopyFileW", CopyFileW);
