+STATIC BOOL WINAPI CryptCATAdminCalcHashFromFileHandle(HANDLE hFile, PDWORD pcbHash, BYTE *pbHash, DWORD dwFlags)
+{
+    DebugLog("%p, %p, %p, %#x", hFile, pcbHash, pbHash, dwFlags);
+
+    if (!pcbHash) {
+        SetLastError(ERROR_INVALID_PARAMETER);
+        return FALSE;
+    }
+
+    DWORD required = 20;
+    if (!pbHash || *pcbHash < required) {
+        *pcbHash = required;
+        SetLastError(ERROR_INSUFFICIENT_BUFFER);
+        return FALSE;
+    }
+
+    FILE *fp = (FILE *)hFile;
+    if (!fp) {
+        SetLastError(ERROR_INVALID_PARAMETER);
+        return FALSE;
+    }
+
+    long pos = ftell(fp);
+    if (pos < 0)
+        pos = 0;
+    fseek(fp, 0, SEEK_SET);
+
+    SHA256_CTX ctx256;
+    SHA1_CTX ctx1;
+    uint8_t buf[4096];
+    size_t nread = 0;
+
+    if (required == 20) {
+        sha1_init(&ctx1);
+    } else {
+        sha256_init(&ctx256);
+    }
+    while ((nread = fread(buf, 1, sizeof(buf), fp)) > 0) {
+        if (required == 20)
+            sha1_update(&ctx1, buf, nread);
+        else
+            sha256_update(&ctx256, buf, nread);
+    }
+    if (required == 20)
+        sha1_final(&ctx1, pbHash);
+    else
+        sha256_final(&ctx256, pbHash);
+
+    fseek(fp, pos, SEEK_SET);
+    *pcbHash = required;
+    SetLastError(ERROR_SUCCESS);
+    return TRUE;
