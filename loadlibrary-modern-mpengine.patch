+static PVOID WINAPI MapViewOfFile(HANDLE hFileMappingObject,
+                                  DWORD dwDesiredAccess,
+                                  DWORD dwFileOffsetHigh,
+                                  DWORD dwFileOffsetLow,
+                                  SIZE_T dwNumberOfBytesToMap)
+{
+    FILE_MAPPING *map = (FILE_MAPPING *)hFileMappingObject;
+    if (!map || map->magic != FILE_MAPPING_MAGIC) {
+        DebugLog("%p => NULL (bad mapping)", hFileMappingObject);
+        return NULL;
+    }
+    off_t offset = ((uint64_t)dwFileOffsetHigh << 32) | dwFileOffsetLow;
+    size_t size = dwNumberOfBytesToMap ? dwNumberOfBytesToMap : map->size;
+    void *addr = mmap(NULL, size, PROT_READ, MAP_PRIVATE, map->fd, offset);
+    if (addr == MAP_FAILED) {
+        DebugLog("%p => NULL (mmap failed, size=%zu, offset=%ld)", hFileMappingObject, size, (long)offset);
+        return NULL;
+    }
+    register_mapping(addr, size);
+    DebugLog("%p => %p (size=%zu, offset=%ld)", hFileMappingObject, addr, size, (long)offset);
+    return addr;
+}
+DECLARE_CRT_EXPORT("MapViewOfFile", MapViewOfFile);
