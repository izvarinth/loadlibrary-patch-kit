+static UINT WINAPI GetTempFileNameW(PWCHAR lpPathName, PWCHAR lpPrefixString, UINT uUnique, PWCHAR lpTempFileName)
+{
+    (void)uUnique;
+    char *path = lpPathName ? CreateAnsiFromWide(lpPathName) : NULL;
+    char *prefix = lpPrefixString ? CreateAnsiFromWide(lpPrefixString) : NULL;
+    const char *dir = (path && *path) ? path : "faketemp";
+    const char *pref = (prefix && *prefix) ? prefix : "tmp";
+    char tmpl[512];
+
+    snprintf(tmpl, sizeof(tmpl), "%s/%sXXXXXX.tmp", dir, pref);
+    int fd = mkstemp(tmpl);
+    if (fd >= 0)
+        close(fd);
+
+    if (lpTempFileName) {
+        size_t len = strlen(tmpl);
+        for (size_t i = 0; i <= len; ++i)
+            lpTempFileName[i] = (WCHAR)tmpl[i];
+    }
+
+    free(path);
+    free(prefix);
+    return fd >= 0 ? 1 : 0;
+}
+DECLARE_CRT_EXPORT("GetTempFileNameW", GetTempFileNameW);
