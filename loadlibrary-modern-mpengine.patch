+/* ntdll Rtl helpers */
+static PCHAR WINAPI RtlIpv4AddressToStringA(PIN_ADDR Address, PCHAR S)
+{
+    if (!Address || !S)
+        return NULL;
+    if (!inet_ntop(AF_INET, Address, S, 16))
+        return NULL;
+    return S + strlen(S);
+}
+
+static PWCHAR WINAPI RtlIpv4AddressToStringW(PIN_ADDR Address, PWCHAR S)
+{
+    char buf[64] = {0};
+    if (!RtlIpv4AddressToStringA(Address, buf) || !S)
+        return NULL;
+    size_t len = strlen(buf);
+    for (size_t i = 0; i <= len; ++i)
+        S[i] = (WCHAR)buf[i];
+    return S + len;
+}
+
+static PCHAR WINAPI RtlIpv6AddressToStringA(PIN6_ADDR Address, PCHAR S)
+{
+    if (!Address || !S)
+        return NULL;
+    if (!inet_ntop(AF_INET6, Address, S, 64))
+        return NULL;
+    return S + strlen(S);
+}
+
+static PWCHAR WINAPI RtlIpv6AddressToStringW(PIN6_ADDR Address, PWCHAR S)
+{
+    char buf[128] = {0};
+    if (!RtlIpv6AddressToStringA(Address, buf) || !S)
+        return NULL;
+    size_t len = strlen(buf);
+    for (size_t i = 0; i <= len; ++i)
+        S[i] = (WCHAR)buf[i];
+    return S + len;
+}
+
+static BOOL WINAPI RtlPrefixUnicodeString(PUNICODE_STRING Prefix, PUNICODE_STRING String, BOOLEAN CaseInsensitive)
+{
+    if (!Prefix || !String || Prefix->Length > String->Length)
+        return FALSE;
+    size_t chars = Prefix->Length / sizeof(WCHAR);
+    for (size_t i = 0; i < chars; ++i) {
+        WCHAR a = Prefix->Buffer[i];
+        WCHAR b = String->Buffer[i];
+        if (CaseInsensitive) {
+            a = (WCHAR)towlower(a);
+            b = (WCHAR)towlower(b);
+        }
+        if (a != b)
+            return FALSE;
+    }
+    return TRUE;
+}
+
+static NTSTATUS WINAPI RtlInitUnicodeStringEx(PUNICODE_STRING DestinationString, PWCHAR SourceString)
+{
+    if (!DestinationString)
+        return STATUS_INVALID_PARAMETER;
+    DestinationString->Buffer = SourceString;
+    if (!SourceString) {
+        DestinationString->Length = 0;
+        DestinationString->MaximumLength = 0;
+        return STATUS_SUCCESS;
+    }
+    size_t len = CountWideChars(SourceString) * sizeof(WCHAR);
+    DestinationString->Length = (USHORT)len;
+    DestinationString->MaximumLength = (USHORT)(len + sizeof(WCHAR));
+    return STATUS_SUCCESS;
+}
