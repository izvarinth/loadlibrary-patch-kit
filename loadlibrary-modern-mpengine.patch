+static int run_verify_helper(const char *file, const char *catalog)
+{
+    const char *helper = getenv("MPENGINE_VERIFY_HELPER");
+    const char *fallback = "./tools/wintrust-verify";
+    char *argv[6];
+    int argc = 0;
+    pid_t pid;
+    int status = 0;
+
+    if (!helper || !*helper) {
+        if (access(fallback, X_OK) == 0) {
+            helper = fallback;
+        } else {
+            helper = "wintrust-verify";
+        }
+    }
+
+    argv[argc++] = (char *)helper;
+    argv[argc++] = "--file";
+    argv[argc++] = (char *)file;
+    if (catalog) {
+        argv[argc++] = "--catalog";
+        argv[argc++] = (char *)catalog;
+    }
+    argv[argc] = NULL;
+
+    pid = fork();
+    if (pid == 0) {
+        execvp(helper, argv);
+        _exit(127);
+    }
+    if (pid < 0) {
+        DebugLog("fork() failed: %m");
+        return -1;
+    }
+
+    if (waitpid(pid, &status, 0) < 0) {
+        DebugLog("waitpid() failed: %m");
+        return -1;
+    }
+
+    if (WIFEXITED(status)) {
+        return WEXITSTATUS(status);
+    }
+
+    return -1;
+}
+
+static bool trace_wintrust_enabled(void)
+{
+    const char *v = getenv("MPENGINE_TRACE_WINTRUST");
+    return v && *v;
+}
